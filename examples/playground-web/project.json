{
  "name": "playground-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "examples/playground-web/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/examples/playground-web",
        "browser": "examples/playground-web/src/main.ts",
        "tsConfig": "examples/playground-web/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "examples/playground-web/public"
          }
        ],
        "styles": ["examples/playground-web/src/styles.css"],
        "server": "examples/playground-web/src/main.server.ts",
        "ssr": {
          "entry": "examples/playground-web/src/server.ts"
        },
        "outputMode": "server"
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "proxyConfig": "examples/playground-web/proxy.config.json"
      },
      "configurations": {
        "production": {
          "buildTarget": "playground-web:build:production"
        },
        "development": {
          "buildTarget": "playground-web:build:development"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "watch": false
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "playground-web:build",
        "staticFilePath": "dist/examples/playground-web/browser",
        "spa": true
      }
    }
  }
}
