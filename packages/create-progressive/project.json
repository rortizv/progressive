{
  "name": "create-progressive",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/create-progressive/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["dist/{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": [],
  "targets": {
    "copy-template": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/create-progressive/template"],
      "options": {
        "command": "rm -rf dist/packages/create-progressive/template && mkdir -p dist/packages/create-progressive && cp -r packages/create-progressive/template dist/packages/create-progressive/template"
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "dependsOn": ["copy-template"],
      "options": {
        "outputPath": "dist/packages/create-progressive",
        "main": "packages/create-progressive/src/index.ts",
        "tsConfig": "packages/create-progressive/tsconfig.lib.json",
        "assets": ["packages/create-progressive/*.md"],
        "clean": false
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    }
  }
}
