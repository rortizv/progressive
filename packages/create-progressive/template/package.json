{
  "name": "__APP_NAME__",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "generate:api": "SWC_NODE_PROJECT=apps/server/tsconfig.app.json node -r @swc-node/register apps/server/scripts/generate-openapi.ts && orval --config orval.config.ts",
    "build": "npm run generate:api && nx run-many -t build -p web,server",
    "start": "node dist/apps/server/main.js",
    "dev": "npm run generate:api && concurrently -n web,server -c blue,magenta \"NG_ALLOWED_HOSTS=localhost nx run web:serve\" \"PORT=3000 nx run server:serve\""
  },
